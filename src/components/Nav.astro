---
import { nav, site } from '../lib/site';
import Icon from './Icon.astro';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-[var(--surface)]/95 backdrop-blur border-b border-[var(--border)]">
  <div class="container-app flex items-center justify-between h-16 md:h-20">
    <a href="/" class="shrink-0">
      <img src="/images/logo-header.png" width="1030" height="343" alt="Tapicería Sacha" class="h-10 md:h-12 w-auto" />
    </a>

    <nav class="hidden md:flex items-center gap-7 text-sm font-medium">
      {nav.map((item) => (
        <a
          href={item.href}
          class={`transition-colors hover:text-[var(--primary)] ${
            currentPath === item.href ? 'text-[var(--primary)]' : 'text-[var(--text)]'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      href={site.whatsapp}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden md:inline-flex items-center gap-2 btn-primary rounded-full px-5 py-2.5 text-sm font-semibold transition-colors"
    >
      <Icon name="whatsapp" class="w-4 h-4" />
      Escríbenos
    </a>

    <button
      id="menu-toggle"
      aria-label="Abrir menú"
      class="md:hidden flex flex-col gap-1.5 p-2"
    >
      <span class="block w-6 h-0.5 bg-[var(--text)]"></span>
      <span class="block w-6 h-0.5 bg-[var(--text)]"></span>
      <span class="block w-6 h-0.5 bg-[var(--text)]"></span>
    </button>
  </div>

  <nav id="mobile-menu" class="hidden md:hidden border-t border-[var(--border)] bg-[var(--surface)]">
    <div class="container-app flex flex-col py-4 gap-1">
      {nav.map((item) => (
        <a
          href={item.href}
          class={`py-2.5 text-sm font-medium ${
            currentPath === item.href ? 'text-[var(--primary)]' : 'text-[var(--text)]'
          }`}
        >
          {item.label}
        </a>
      ))}
      <a
        href={site.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex items-center justify-center gap-2 btn-primary rounded-full px-5 py-2.5 text-sm font-semibold"
      >
        <Icon name="whatsapp" class="w-4 h-4" />
        Escríbenos por WhatsApp
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
