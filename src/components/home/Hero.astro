---
import { site } from '../../lib/site';
import Icon from '../Icon.astro';

const heroImage = 'https://media.base44.com/images/public/6a4bf3f491c58fd26a7f290b/6af876615_generated_image.png';
---

<section class="relative min-h-[85vh] w-full overflow-hidden bg-[#ede6da] flex items-center">
  <div class="absolute inset-0">
    <img
      src={heroImage}
      alt="Maestro tapicero trabajando con aguja e hilo dorado sobre terciopelo"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>

  <div class="container-app relative z-10 py-20 text-white">
    <p class="text-xs md:text-sm font-semibold uppercase tracking-[0.2em] text-[#e9c98a] mb-4">
      Más de una década de experiencia
    </p>
    <h1 class="font-heading text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] max-w-2xl mb-5">
      La Perfección en cada Puntada
    </h1>
    <p class="text-base md:text-lg text-white/85 max-w-xl mb-8 leading-relaxed">
      El buen diseño consiste en convertir sueños en realidad. Renovamos, restauramos y confeccionamos muebles a la medida en Medellín.
    </p>
    <div class="flex flex-wrap gap-4">
      <a
        href={site.whatsappWithText('Hola, me gustaría cotizar un servicio de tapicería.')}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 btn-primary rounded-full px-7 py-3.5 text-sm font-semibold transition-colors"
      >
        <Icon name="whatsapp" class="w-5 h-5" />
        Cotiza por WhatsApp
      </a>
      <a
        href="/productos"
        class="inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-sm font-semibold border border-white/40 text-white hover:bg-white/10 transition-colors"
      >
        Ver catálogo completo
        <Icon name="arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>
